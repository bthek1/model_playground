# direnv — automatically sourced when entering backend/
# Run `direnv allow` after creating or modifying this file.

# Activate the uv-managed virtual environment
# Requires direnv >= 2.32 with uv layout support.
# See: https://github.com/direnv/direnv/wiki/Python#uv
VIRTUAL_ENV="$PWD/.venv"
export VIRTUAL_ENV
PATH_add "$VIRTUAL_ENV/bin"

# Load backend environment variables
source_env_if_exists .env

# Python path so manage.py and imports resolve correctly
export PYTHONPATH="$PWD:$PYTHONPATH"
