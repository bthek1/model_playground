{
  // ── Python / pytest ────────────────────────────────────────────────────────
  "python.defaultInterpreterPath": "${workspaceFolder}/backend/.venv/bin/python3",
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestPath": "${workspaceFolder}/backend/.venv/bin/pytest",
  "python.testing.pytestArgs": [
    "--rootdir=${workspaceFolder}/backend",
    "--tb=short",
    "--no-header"
  ],
  "python.testing.cwd": "${workspaceFolder}/backend",
  "python.envFile": "${workspaceFolder}/backend/.env",

  // ── Vitest ─────────────────────────────────────────────────────────────────
  "vitest.enable": true,
  "vitest.rootConfig": "${workspaceFolder}/frontend/vite.config.ts",
  "vitest.workspaceConfig": "",
  "vitest.nodeExecutable": "",

  // ── Editor ─────────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
}
